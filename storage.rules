rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /business/{userId}.jpg {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024;
    }
    match /products/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024;
    }
  }
}
